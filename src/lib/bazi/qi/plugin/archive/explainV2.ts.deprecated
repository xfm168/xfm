/**
 * ExplainV2 — P2-3.5 四层解释引擎
 *
 * 根据同一命盘分析结果，生成四层不同深度的解释：
 *   ① 专业版（professional）— 学术术语，引用古籍
 *   ② 白话版（vernacular）— 日常语言，通俗易懂
 *   ③ 新手版（beginner）— 零基础友好，比喻类比
 *   ④ 行动建议版（action）— 按领域/时段，宜忌明确
 *
 * 特性：
 *   - 每个章节至少一条古籍引用
 *   - 模板变量 + 随机选择器避免机械重复
 *   - 核心结论保持一致，表达方式多样
 */

import type { FiveElement } from '../../types'
import type { PatternValidationResult } from './patternValidator'
import type { DayMasterStrengthResult } from './dayMasterStrengthEngine'
import type { ClimateAdjustmentResult } from './climateAdjustmentEngine'
import type { UseGodResult } from './useGodEngine'
import type { DiseaseMedicineResult } from './diseaseMedicineEngine'
import type { TongGuanResult } from './tongGuanEngine'
import type { ClassicKnowledgeEntry } from './classicKnowledgeBase'

// ─── 类型导出 ───

export type ExplainLayer = 'professional' | 'vernacular' | 'beginner' | 'action'

export interface ExplainV2Section {
  title: string
  content: string
  classicalRef?: string
}

export interface ExplainV2Result {
  professional: ExplainV2Section[]
  vernacular: ExplainV2Section[]
  beginner: ExplainV2Section[]
  action: ExplainV2Section[]
  overallSummary: string
  confidence: number
}

export interface ExplainV2Context {
  dayGan: string
  monthZhi: string
  fourPillars: string       // 如"辛卯 庚寅 丁酉 壬寅"
  geJuName: string
  geJuResult: any           // GeJuResult
  strength: DayMasterStrengthResult
  climate: ClimateAdjustmentResult
  disease: DiseaseMedicineResult
  tongGuan: TongGuanResult
  useGod: UseGodResult
  pattern: PatternValidationResult
  shenSha?: any             // ShenShaResult（可选）
  knowledgeBase?: ClassicKnowledgeEntry[] // 相关古籍条目（可选）
}

// ─── 五行关系常量 ───

const ELEMENT_MAP: Record<string, FiveElement> = {
  '甲': '木', '乙': '木', '丙': '火', '丁': '火',
  '戊': '土', '己': '土', '庚': '金', '辛': '金',
  '壬': '水', '癸': '水',
}

const GENERATE: Record<FiveElement, FiveElement> = {
  '木': '火', '火': '土', '土': '金', '金': '水', '水': '木',
}

const OVERCOME: Record<FiveElement, FiveElement> = {
  '木': '土', '土': '水', '水': '火', '火': '金', '金': '木',
}

const ELEMENT_SEASON: Record<FiveElement, string> = {
  '木': '春', '火': '夏', '土': '长夏/四季', '金': '秋', '水': '冬',
}

const SHI_SHEN_NAMES: Record<string, string> = {
  '比肩': '比劫', '劫财': '比劫', '食神': '食伤', '伤官': '食伤',
  '正财': '财星', '偏财': '财星', '正官': '官杀', '七杀': '官杀',
  '正印': '印星', '偏印': '印星',
}

