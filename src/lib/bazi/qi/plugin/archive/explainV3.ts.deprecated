export function getI18n(lang: ExplainV3Language): ExplainV3I18n {
  if (lang === 'zh-CN') return I18N_ZH_CN
  if (lang === 'zh-TW') {
    return {
      ...buildPlaceholderI18n(),
      professional: '命理專業版',
      vernacular: '白話版',
      action: '行動建議',
      risk: '風險提示',
      classical: '古籍依據',
      similar: '相似案例',
      aiAdvice: 'AI綜合建議',
      overallSummary: '整體摘要',
      confidence: '置信度',
      language: '語言',
      readingLevel: '閱讀等級',
      riskLevel: { '极低': '極低', '低': '低', '中': '中', '高': '高', '极高': '極高' },
      recommendation: { '强烈建议': '強烈建議', '建议': '建議', '中性': '中性', '不建议': '不建議', '强烈不建议': '強烈不建議' },
      dimensionNames: { career: '事業', wealth: '財富', marriage: '婚姻', health: '健康', study: '學業', patron: '貴人運' },
    }
  }
  return buildPlaceholderI18n()
}

// ─── 随机选择器工具 ───

function pick<T>(arr: T[]): T {
  return arr[Math.floor(Math.random() * arr.length)]
}

function pickN<T>(arr: T[], n: number): T[] {
  const shuffled = [...arr].sort(() => Math.random() - 0.5)
  return shuffled.slice(0, Math.min(n, arr.length))
}

/** 获取古籍引用，优先使用 knowledgeBase，否则使用内置默认 */
function getClassicalRef(
  category: string,
  keyword: string,
  knowledgeBase?: any[],
): string {
  if (knowledgeBase && knowledgeBase.length > 0) {
    const matches = knowledgeBase.filter(
      (e: any) =>
        (e.originalText && e.originalText.includes(keyword)) ||
        (e.vernacular && e.vernacular.includes(keyword)) ||
        (e.keywords && e.keywords.some((k: string) => k.includes(keyword.toLowerCase())))
    )
    if (matches.length > 0) {
      const entry = pick(matches)
      return `《${entry.source}》${entry.chapter ? entry.chapter + '：' : ''}"${entry.originalText}"`
    }
  }
  const defaults = DEFAULT_CLASSICAL_REFS[category]
  return defaults ? pick(defaults) : ''
}

/** 获取某分类的全部引用 */
function getAllClassicalRefs(category: string): string[] {
  return DEFAULT_CLASSICAL_REFS[category] || []
}

