/**
 * ExplainV3 — P3.8 七层解释引擎
 *
 * 基于同一命盘的全部分析结果（V2 + P3 引擎），生成七层不同维度的解释：
 *   ① professional — 命理专业版（学术术语，引用古籍）
 *   ② vernacular   — 白话版（日常语言，通俗易懂）
 *   ③ action       — 行动建议（按领域/时段，宜忌明确）
 *   ④ risk         — 风险提示（基于概率引擎和事件预测的风险等级分析）
 *   ⑤ classical    — 古籍依据（集中引用相关古籍原文+解读）
 *   ⑥ similar      — 相似案例（基于 SimilarityEngine 的 TOP3 相似案例摘要）
 *   ⑦ aiAdvice     — AI综合建议（跨引擎综合分析，给出务实建议）
 *
 * 特性：
 *   - 纯 Plugin，不修改 Kernel
 *   - import type 仅引入类型
 *   - 所有输出内容中文字符串，保留多语言架构
 *   - pick() / pickN() 随机选择器避免模板化
 *   - 每层至少一条古籍引用
 *   - 核心结论跨层一致，表达方式多样
 *   - readingLevel 影响术语密度和解释深度
 */

import type { FiveElement } from '../../types'

// ─── 类型导出 ───

export type ExplainV3Language = 'zh-CN' | 'zh-TW' | 'en' | 'ja' | 'ko'

export type ExplainV3ReadingLevel = 'expert' | 'intermediate' | 'beginner'

export interface ExplainV3Section {
  title: string
  content: string
  classicalRef?: string
}

export interface ExplainV3Result {
  /** 7层输出 */
  professional: ExplainV3Section[]
  vernacular: ExplainV3Section[]
  action: ExplainV3Section[]
  risk: ExplainV3Section[]
  classical: ExplainV3Section[]
  similar: ExplainV3Section[]
  aiAdvice: ExplainV3Section[]
  /** 整体摘要（根据阅读等级自动调整） */
  overallSummary: string
  /** 置信度 */
  confidence: number
  /** 使用的语言 */
  language: ExplainV3Language
  /** 阅读等级 */
  readingLevel: ExplainV3ReadingLevel
}

export interface ExplainV3Context {
  // 基础四柱信息
  dayGan: string
  monthZhi: string
  fourPillars: string
  geJuName: string

  // V2 层面的分析结果
  geJuResult: any
  strength: any  // DayMasterStrengthResult
  climate: any  // ClimateAdjustmentResult
  disease: any  // DiseaseMedicineResult
  tongGuan: any  // TongGuanResult
  useGod: any    // UseGodResult
  pattern: any  // PatternValidationResult

  // P3 引擎结果（可选但推荐）
  probabilityResult?: any    // ProbabilityResult from probabilityEngine
  timelineResult?: any       // TimelineResult from timelineEngine
  eventResult?: any          // EventPredictionResult from eventPredictionEngine
  decisionResult?: any       // DecisionResult or DecisionResultAll from decisionEngine
  similarResult?: any       // SimilarityResult from similarityEngine

  // 神煞（可选）
  shenSha?: any              // ShenShaResult

  // 古籍知识库（可选）
  knowledgeBase?: any[]      // ClassicKnowledgeEntry[]

  // 输出配置
  language?: ExplainV3Language
  readingLevel?: ExplainV3ReadingLevel
}

// ─── 多语言 I18n 接口 ───

export interface ExplainV3I18n {
  professional: string
  vernacular: string
  action: string
  risk: string
  classical: string
  similar: string
  aiAdvice: string
  overallSummary: string
  confidence: string
  language: string
  readingLevel: string
  riskLevel: Record<string, string>
  recommendation: Record<string, string>
  dimensionNames: Record<string, string>
  uiLabels: {
    positive: string
    negative: string
    advice: string
    source: string
    credibility: string
    keyEvents: string
    doThis: string
    avoidThis: string
    riskLevelLabel: string
    copingStrategy: string
    classicalSource: string
    vernacularInterpretation: string
    caseName: string
    similarity: string
    trustLevel: string
    traditionalConclusion: string
    lifeEvents: string
    commonPoints: string
    differences: string
    coreAdvice: string
    sourceEngines: string
    confidenceLabel: string
  }
}

