  geJuName: '正印格',
  geJuResult: {},
  strength: { strengthScore: 55, strengthLevelCN: '中和', deLing: false, deDi: true, deShi: false, tongGen: false, touGan: false, wangShuai: '休', shengFuPower: 50, keXiePower: 50, changShengDetails: [], dimensions: [] },
  climate: { climateType: '寒', climateScore: 45, monthClimate: '子月隆冬', dayGanClimate: '甲木生于子月', needsAdjustment: true, needs: [{ element: '火', preferredStems: ['丙', '丁'], description: '寒木向阳', source: '穷通宝鉴', priority: 1 }], advice: '寒木需火' },
