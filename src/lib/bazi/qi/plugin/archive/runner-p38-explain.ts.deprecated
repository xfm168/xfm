check('similar是数组', Array.isArray(result.similar))
check('similar长度>=2', result.similar.length >= 2)

// 包含案例名
const similarAllText = result.similar.map((s: any) => s.content).join('')
check('similar包含案例名', similarAllText.includes('乾隆帝'))

// 包含相似度分数
const hasSimilarityScore = similarAllText.includes('85') || similarAllText.includes('相似')
check('similar包含相似度', hasSimilarityScore)

// ═══════════════════════════════════════════════
// 8. aiAdvice（AI综合建议）— 全新层
// ═══════════════════════════════════════════════
console.log('\n--- 8. aiAdvice（AI综合建议）---')

check('aiAdvice是数组', Array.isArray(result.aiAdvice))
check('aiAdvice长度>=2', result.aiAdvice.length >= 2)

for (const sec of result.aiAdvice) {
  check(`aiAdvice section: "${sec.title}" 非空`, sec.title.length > 0 && sec.content.length > 10)
}

// AI建议应包含具体可执行的内容
const aiAllText = result.aiAdvice.map((s: any) => s.content).join('')
check('aiAdvice包含具体建议', aiAllText.length > 100)

// ═══════════════════════════════════════════════
// 9. 多语言支持测试
// ═══════════════════════════════════════════════
console.log('\n--- 9. 多语言支持 ---')

// 9a. getI18n 各语言可获取
const zhCN = getI18n('zh-CN')
check('getI18n(zh-CN) 返回对象', zhCN !== null && typeof zhCN === 'object')

const zhTW = getI18n('zh-TW')
check('getI18n(zh-TW) 返回对象', zhTW !== null && typeof zhTW === 'object')

const en = getI18n('en')
check('getI18n(en) 返回对象', en !== null && typeof en === 'object')

const ja = getI18n('ja')
check('getI18n(ja) 返回对象', ja !== null && typeof ja === 'object')

// 9b. 不同语言生成结果
const resultEN = generateExplainV3({ ...ctx, language: 'en' })
check('英文版生成成功', resultEN.language === 'en')
check('英文版7层齐全', !!resultEN.professional && !!resultEN.vernacular && !!resultEN.aiAdvice)

const resultJA = generateExplainV3({ ...ctx, language: 'ja' })
check('日文版生成成功', resultJA.language === 'ja')

// 9c. zh-CN 版本应包含中文
const zhCNText = result.overallSummary
check('zh-CN包含中文', zhCNText.includes('格局') || zhCNText.includes('用神'))

// ═══════════════════════════════════════════════
// 10. 阅读等级测试
// ═══════════════════════════════════════════════
console.log('\n--- 10. 阅读等级 ---')

// 10a. expert
const resultExpert = generateExplainV3({ ...ctx, readingLevel: 'expert' })
check('expert等级生成成功', resultExpert.readingLevel === 'expert')
check('expert summary非空', resultExpert.overallSummary.length > 10)

// 10b. beginner
const resultBeginner = generateExplainV3({ ...ctx, readingLevel: 'beginner' })
check('beginner等级生成成功', resultBeginner.readingLevel === 'beginner')
check('beginner summary非空', resultBeginner.overallSummary.length > 10)

// 10c. 不同等级的 summary 应有差异（术语密度不同）
// 精确对比：expert summary 比 beginner 更可能包含学术术语
const expertHasTerm = resultExpert.overallSummary.includes('格局') || resultExpert.overallSummary.includes('用神') || resultExpert.overallSummary.includes('旺衰')
const beginnerHasSimple = resultBeginner.overallSummary.includes('你') || resultBeginner.overallSummary.includes('适合')
check('expert/beginner summary有差异', expertHasTerm || beginnerHasSimple)

// ═══════════════════════════════════════════════
// 11. 缺省 P3 引擎结果测试
// ═══════════════════════════════════════════════
console.log('\n--- 11. 缺省P3引擎结果 ---')

