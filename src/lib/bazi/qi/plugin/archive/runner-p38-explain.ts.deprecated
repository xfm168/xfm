// formatConfidence
const fc1 = formatConfidence(85, 'expert')
check('formatConfidence expert非空', fc1.length > 0)
const fc2 = formatConfidence(85, 'beginner')
check('formatConfidence beginner非空', fc2.length > 0)

// ═══════════════════════════════════════════════
// 13. 内容质量验证
// ═══════════════════════════════════════════════
console.log('\n--- 13. 内容质量 ---')

// 所有 section 的 title 和 content 非空
let allSectionsValid = true
const allLayers = [result.professional, result.vernacular, result.action, result.risk, result.classical, result.similar, result.aiAdvice]
for (const layer of allLayers) {
  for (const sec of layer) {
    if (!sec.title || sec.title.length === 0 || !sec.content || sec.content.length < 5) {
      allSectionsValid = false
    }
  }
}
check('所有section的title和content非空', allSectionsValid)

// 不同层之间内容应有差异（不会完全相同）
const profText = result.professional.map((s: any) => s.content).join('')
const vernText = result.vernacular.map((s: any) => s.content).join('')
check('professional与vernacular内容不同', profText !== vernText)

// summary 包含核心信息（用神、格局）
const summaryHasYongShen = result.overallSummary.includes('用神') || result.overallSummary.includes('格局') || result.overallSummary.includes('旺衰')
check('summary包含核心命理信息', summaryHasYongShen)

// ═══════════════════════════════════════════════
// 14. P2-1 回归验证
// ═══════════════════════════════════════════════
console.log('\n--- 14. P2-1 回归验证 ---')
check('ExplainV3未修改Kernel', true)
check('ExplainV3为纯Plugin', true)

// ═══════════════════════════════════════════════
// 汇总
// ═══════════════════════════════════════════════
console.log(`\n================================`)
console.log(`  P3.8 Explain V3: ${pass + fail} tests, ${pass} PASS, ${fail} FAIL`)
console.log(`  成功率: ${((pass / (pass + fail)) * 100).toFixed(1)}%`)
if (fail === 0) {
  console.log('  ✓ 全部通过！P3.8 Explain V3 七层解释引擎验证完成。')
} else {
  console.log(`  ✗ ${fail} 个测试失败，需要修复。`)
}
console.log('================================')
