/**
 * P3.8 Explain V3 七层解释引擎 测试验证
 */
import { generateExplainV3, getI18n, translateTerm, formatConfidence } from './explainV3'

let pass = 0, fail = 0
function check(name: string, ok: boolean) {
  console.log(`  [${ok ? 'PASS' : 'FAIL'}] ${name}`)
  if (ok) { pass++ } else { fail++ }
}

// ═══════════════════════════════════════════════
