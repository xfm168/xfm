console.log('=== P3.8 Explain V3 七层解释引擎 测试 ===\n')

// ═══════════════════════════════════════════════
// 1. 基础功能测试
// ═══════════════════════════════════════════════
console.log('--- 1. 基础功能 ---')

const ctx = makeMockContext()
const result = generateExplainV3(ctx)

check('返回结果存在', result !== null && result !== undefined)
check('7层输出均有', !!result.professional && !!result.vernacular && !!result.action && !!result.risk && !!result.classical && !!result.similar && !!result.aiAdvice)
check('overallSummary非空', result.overallSummary.length > 10)
check('confidence >0', result.confidence > 0)
check('confidence <=100', result.confidence <= 100)
check('language = zh-CN', result.language === 'zh-CN')
check('readingLevel = intermediate', result.readingLevel === 'intermediate')

// ═══════════════════════════════════════════════
// 2. professional（命理专业版）
// ═══════════════════════════════════════════════
console.log('\n--- 2. professional（命理专业版）---')

check('professional是数组', Array.isArray(result.professional))
check('professional长度>=4', result.professional.length >= 4)

for (const sec of result.professional) {
  check(`professional section: "${sec.title}" 非空`, sec.title.length > 0 && sec.content.length > 10)
}

// 包含格局分析
const geJuSec = result.professional.find((s: any) => s.title.includes('格局'))
check('professional包含格局分析', !!geJuSec)

// 包含概率推演（P3新增）
const probSec = result.professional.find((s: any) => s.title.includes('概率') || s.title.includes('推演'))
check('professional包含概率推演(P3)', !!probSec)

// 包含时间轴（P3新增）
const timeSec = result.professional.find((s: any) => s.title.includes('时间') || s.title.includes('轨迹'))
check('professional包含人生时间轴(P3)', !!timeSec)

// 至少一个section有古籍引用
const profWithRef = result.professional.filter((s: any) => s.classicalRef && s.classicalRef.length > 5)
check('professional有古籍引用', profWithRef.length > 0)

// ═══════════════════════════════════════════════
// 3. vernacular（白话版）
// ═══════════════════════════════════════════════
console.log('\n--- 3. vernacular（白话版）---')

check('vernacular是数组', Array.isArray(result.vernacular))
check('vernacular长度>=4', result.vernacular.length >= 4)

for (const sec of result.vernacular) {
  check(`vernacular section: "${sec.title}" 非空`, sec.title.length > 0 && sec.content.length > 10)
}

// 白话版不应用过于学术的术语
const vernAllText = result.vernacular.map((s: any) => s.content).join('')
check('白话版包含"你"', vernAllText.includes('你'))

// 包含运势概况（P3新增）
const fortuneSec = result.vernacular.find((s: any) => s.title.includes('运势') || s.title.includes('概况'))
check('vernacular包含运势概况(P3)', !!fortuneSec)

// ═══════════════════════════════════════════════
// 4. action（行动建议）
// ═══════════════════════════════════════════════
console.log('\n--- 4. action（行动建议）---')

check('action是数组', Array.isArray(result.action))
check('action长度>=4', result.action.length >= 4)

// 包含宜/忌
const actionAllText = result.action.map((s: any) => s.content).join('')
check('action包含"宜"', actionAllText.includes('宜'))
check('action包含"忌"', actionAllText.includes('忌'))

// 包含事业建议
const careerSec = result.action.find((s: any) => s.title.includes('事业'))
check('action包含事业建议', !!careerSec)

// 包含阶段规划
const timelineSec = result.action.find((s: any) => s.title.includes('阶段') || s.title.includes('规划'))
check('action包含阶段规划', !!timelineSec)

// ═══════════════════════════════════════════════
// 5. risk（风险提示）— 全新层
// ═══════════════════════════════════════════════
console.log('\n--- 5. risk（风险提示）---')

check('risk是数组', Array.isArray(result.risk))
check('risk长度>=2', result.risk.length >= 2)

for (const sec of result.risk) {
  check(`risk section: "${sec.title}" 非空`, sec.title.length > 0 && sec.content.length > 10)
}

// 包含风险等级描述
const riskAllText = result.risk.map((s: any) => s.content).join('')
const hasRiskLevel = ['极低', '低', '中', '高', '极高'].some((l: string) => riskAllText.includes(l))
check('risk包含风险等级', hasRiskLevel)

// ═══════════════════════════════════════════════
// 6. classical（古籍依据）— 全新层
// ═══════════════════════════════════════════════
console.log('\n--- 6. classical（古籍依据）---')

check('classical是数组', Array.isArray(result.classical))
check('classical长度>=4', result.classical.length >= 4)

for (const sec of result.classical) {
  check(`classical section: "${sec.title}" 非空`, sec.title.length > 0 && sec.content.length > 10)
}

// 古籍引用层必须包含《
const classAllText = result.classical.map((s: any) => s.content).join('')
check('classical包含古籍书名号', classAllText.includes('《'))

// ═══════════════════════════════════════════════
// 7. similar（相似案例）— 全新层
// ═══════════════════════════════════════════════
